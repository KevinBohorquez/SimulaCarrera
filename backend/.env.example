# IA — Groq es 100% GRATIS, sin tarjeta ni billing
# Regístrate en https://console.groq.com → API Keys → Create
AI_PROVIDER=groq
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (alternativa — puede pedir billing en cuentas nuevas con keys AQ.)
# AI_PROVIDER=gemini
# GEMINI_API_KEY=AIza... o AQ....
# AI_MODEL=gemini-2.0-flash

# OpenAI (de pago)
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# AI_MODEL=gpt-4o-mini
