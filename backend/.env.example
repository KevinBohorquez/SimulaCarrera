# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173

# Supabase (de tu propio proyecto)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...           # pública, para validar JWT
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # SECRETO, bypassa RLS

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Email (SMTP). Si no se configura, los emails se logean en consola.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="SimulaCarrera <no-reply@simulacarrera.app>"

# Buckets de Supabase Storage
STORAGE_BUCKET_REPORTS=reports
STORAGE_BUCKET_LOGOS=logos
STORAGE_BUCKET_CSV=csv-imports
