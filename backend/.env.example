# Server
PORT=4000
NODE_ENV=development
# URLs del frontend (separadas por coma si hay varias). Obligatorio en producción.
CORS_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173

# Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# IA — Groq es 100% GRATIS, sin tarjeta ni billing
# Regístrate en https://console.groq.com → API Keys → Create
AI_PROVIDER=groq
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (alternativa)
# AI_PROVIDER=gemini
# GEMINI_API_KEY=AIza...
# AI_MODEL=gemini-2.0-flash

# OpenAI (de pago)
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# AI_MODEL=gpt-4o-mini

# Email (SMTP). Si no se configura, los emails se logean en consola.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="SimulaCarrera <no-reply@simulacarrera.app>"

# Buckets de Supabase Storage
STORAGE_BUCKET_REPORTS=reports
STORAGE_BUCKET_LOGOS=logos
STORAGE_BUCKET_CSV=csv-imports
